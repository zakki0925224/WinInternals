{
    "version": 3,
    "configurePresets": [
        {
            "name": "x86-debug",
            "displayName": "x86 Debug",
            "generator": "Ninja",
            "architecture": {
                "value": "x86",
                "strategy": "external"
            },
            "toolset": {
                "value": "host=x86",
                "strategy": "external"
            },
            "binaryDir": "${sourceDir}/build/x86-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "cl.exe"
            }
        },
        {
            "name": "x64-debug",
            "displayName": "x64 Debug",
            "generator": "Ninja",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "binaryDir": "${sourceDir}/build/x64-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "cl.exe"
            }
        }
    ]
}
